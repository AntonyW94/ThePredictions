@page "/admin/teams"

@attribute [Authorize(Roles = RoleNames.Administrator)]

@inject HttpClient Http
@inject NavigationManager NavigationManager

@using ThePredictions.Contracts.Admin.Teams
@using ThePredictions.Contracts.Admin.Seasons

<PageTitle>Manage Teams</PageTitle>

<div class="page-container admin-light">
    <div class="admin-content-container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold mb-0">Manage Teams</h3>
            <button class="btn d-flex align-items-center green-button" @onclick='() => NavigationManager.NavigateTo("/admin/teams/create")'>
                <span class="bi bi-plus-circle-fill"></span>
                <span class="d-none d-md-inline ms-2">Create Team</span>
            </button>
        </div>

        @if (_seasons != null)
        {
            <div class="filter-row">
                <button class="filter-card @(_selectedSeasonId == null ? "active" : "")" @onclick="() => FilterBySeasonAsync(null)">
                    All
                </button>

                @foreach (var season in _seasons)
                {
                    <button class="filter-card @(_selectedSeasonId == season.Id ? "active" : "")" @onclick="() => FilterBySeasonAsync(season.Id)">
                        @season.Name
                    </button>
                }
            </div>
        }

        @if (_teams == null)
        {
            <p class="text-center"><em>Loading teams...</em></p>
        }
        else
        {
            <div class="team-grid">
                @foreach (var team in _teams)
                {
                    <div class="card thumbnail" @onclick="() => EditTeam(team.Id)">
                        <div class="team-card-logo-bg">
                            <img src="@team.LogoUrl" alt="@team.Name logo" class="team-card-logo" />
                        </div>

                        <div class="team-card-body">
                            <h5 class="team-card-name">@team.Name</h5>
                            <button class="btn btn-sm w-100 green-button">Edit</button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private List<TeamDto>? _teams;
    private List<SeasonDto>? _seasons;
    private int? _selectedSeasonId;

    protected override async Task OnInitializedAsync()
    {
        _seasons = await Http.GetFromJsonAsync<List<SeasonDto>>("api/admin/seasons");
        _teams = await Http.GetFromJsonAsync<List<TeamDto>>("api/admin/teams");
    }

    private async Task FilterBySeasonAsync(int? seasonId)
    {
        _selectedSeasonId = seasonId;

        var url = seasonId.HasValue
            ? $"api/admin/teams?seasonId={seasonId}"
            : "api/admin/teams";

        _teams = await Http.GetFromJsonAsync<List<TeamDto>>(url);
    }

    private void EditTeam(int teamId)
    {
        NavigationManager.NavigateTo($"/admin/teams/edit/{teamId}");
    }
}