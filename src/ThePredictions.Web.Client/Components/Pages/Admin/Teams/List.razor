@page "/admin/teams"

@attribute [Authorize(Roles = RoleNames.Administrator)]

@inject HttpClient Http
@inject NavigationManager NavigationManager

@using ThePredictions.Contracts.Admin.Teams
@using ThePredictions.Contracts.Admin.Seasons

<PageTitle>Manage Teams</PageTitle>

<div class="page-container admin-light">
    <div class="admin-table-container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold mb-0">Manage Teams</h3>
            <button class="btn d-flex align-items-center green-button" @onclick='() => NavigationManager.NavigateTo("/admin/teams/create")'>
                <span class="bi bi-plus-circle-fill"></span>
                <span class="d-none d-md-inline ms-2">Create Team</span>
            </button>
        </div>

        @if (_seasons != null)
        {
            <div class="admin-tabs-mobile">
                <select @onchange="OnMobileFilterChanged">
                    <option value="" selected="@(_selectedSeasonId == null)">All (@_allTeamCount)</option>
                    @foreach (var season in _seasons)
                    {
                        <option value="@season.Id" selected="@(_selectedSeasonId == season.Id)">
                            @season.Name (@(_seasonTeamCounts.TryGetValue(season.Id, out var count) ? count : 0))
                        </option>
                    }
                </select>
            </div>

            <div class="filter-row">
                <button class="filter-card @(_selectedSeasonId == null ? "active" : "")" @onclick="() => FilterBySeasonAsync(null)">
                    All
                    <span class="match-count-badge ms-1">@_allTeamCount</span>
                </button>

                @foreach (var season in _seasons)
                {
                    <button class="filter-card @(_selectedSeasonId == season.Id ? "active" : "")" @onclick="() => FilterBySeasonAsync(season.Id)">
                        @season.Name
                        @if (_seasonTeamCounts.TryGetValue(season.Id, out var cnt))
                        {
                            <span class="match-count-badge ms-1">@cnt</span>
                        }
                    </button>
                }
            </div>
        }

        @if (_teams == null)
        {
            <div class="d-flex justify-content-center align-items-center py-5">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else if (!_teams.Any())
        {
            <div class="empty-state">
                <span class="bi bi-shield empty-state-icon"></span>
                <p class="empty-state-title">No teams found</p>
                <p class="empty-state-text">Teams for this filter will appear here.</p>
            </div>
        }
        else
        {
            <div class="team-list-grid">
                @foreach (var team in _teams)
                {
                    <div class="member-row team-list-row" @onclick="() => EditTeam(team.Id)">
                        <img src="@team.LogoUrl" alt="@team.Name" class="team-list-logo" />
                        <div class="member-info">
                            <span class="member-name">@team.Name</span>
                            <span class="member-date">@team.Abbreviation</span>
                        </div>
                        <span class="bi bi-chevron-right team-list-chevron"></span>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private List<TeamDto>? _teams;
    private List<SeasonDto>? _seasons;
    private int? _selectedSeasonId;
    private int _allTeamCount;
    private Dictionary<int, int> _seasonTeamCounts = new();

    protected override async Task OnInitializedAsync()
    {
        _seasons = await Http.GetFromJsonAsync<List<SeasonDto>>("api/admin/seasons");
        _teams = await Http.GetFromJsonAsync<List<TeamDto>>("api/admin/teams");
        _allTeamCount = _teams?.Count ?? 0;

        if (_seasons != null)
        {
            foreach (var season in _seasons)
            {
                var seasonTeams = await Http.GetFromJsonAsync<List<TeamDto>>($"api/admin/teams?seasonId={season.Id}");
                _seasonTeamCounts[season.Id] = seasonTeams?.Count ?? 0;
            }
        }
    }

    private async Task OnMobileFilterChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        int? seasonId = string.IsNullOrEmpty(value) ? null : int.Parse(value);
        await FilterBySeasonAsync(seasonId);
    }

    private async Task FilterBySeasonAsync(int? seasonId)
    {
        _selectedSeasonId = seasonId;

        var url = seasonId.HasValue
            ? $"api/admin/teams?seasonId={seasonId}"
            : "api/admin/teams";

        _teams = await Http.GetFromJsonAsync<List<TeamDto>>(url);
    }

    private void EditTeam(int teamId)
    {
        NavigationManager.NavigateTo($"/admin/teams/edit/{teamId}");
    }
}
