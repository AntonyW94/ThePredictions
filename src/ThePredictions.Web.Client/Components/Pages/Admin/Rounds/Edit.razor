@page "/admin/rounds/edit/{RoundId:int}"

@attribute [Authorize(Roles = RoleNames.Administrator)]

@inject HttpClient Http

@using ThePredictions.Contracts.Admin.Matches
@using ThePredictions.Contracts.Admin.Rounds
@using ThePredictions.Contracts.Admin.Teams
@using ThePredictions.Domain.Common.Enumerations

<PageTitle>Edit Round</PageTitle>

<div class="page-container admin-light">
    <div class="form-container extra-wide">
        <ApiError Message="@_errorMessage"></ApiError>

        @if (_model == null)
        {
            <div class="d-flex justify-content-center align-items-center h-100">
                <div class="spinner-border text-white" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            <BaseFormComponent TModel="UpdateRoundRequest"
                               Model="_model"
                               SubmitAction="HandleUpdateRoundAsync"
                               SuccessRedirectUrl="@($"/admin/seasons/{_seasonId}/rounds")"
                               BackUrl="@($"/admin/seasons/{_seasonId}/rounds")"
                               SuccessAlertMessage="Round updated successfully!"
                               BusyText="Saving...">
                <ChildContent>
                    <!-- Round Header - Title + Metadata -->
                    <div class="admin-light-header">
                        <h3 class="fw-bold">Edit Round</h3>
                        <div class="row gx-3 align-items-end">
                            <div class="col-4">
                                <label for="roundNumber" class="form-label">Round No</label>
                                <InputNumber id="roundNumber" class="form-control" @bind-Value="_model.RoundNumber" />
                            </div>

                            <div class="col-8">
                                <label for="apiRoundName" class="form-label">API Round Name</label>
                                <InputText id="apiRoundName" class="form-control" @bind-Value="_model.ApiRoundName" />
                            </div>
                        </div>

                        <div class="row gx-3 align-items-end mt-3">
                            <div class="col-12 col-md-4">
                                <label for="status" class="form-label">Status</label>
                                <InputSelect id="status" class="form-control" @bind-Value="_model.Status">
                                    @foreach (RoundStatus status in Enum.GetValues(typeof(RoundStatus)))
                                    {
                                        <option value="@status">@status.GetDescription()</option>
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-12 col-md-4 mt-3 mt-md-0">
                                <label for="startDate" class="form-label">Start Date</label>
                                <UtcInputDate id="startDate" Class="form-control" @bind-Value="_model.StartDateUtc" />
                            </div>

                            <div class="col-12 col-md-4 mt-3 mt-md-0">
                                <label for="deadline" class="form-label">Deadline</label>
                                <UtcInputDate id="deadline" Class="form-control" @bind-Value="_model.DeadlineUtc" />
                            </div>
                        </div>
                    </div>

                    <!-- Matches Section -->
                    <div class="matches-section">
                        <div class="matches-header">
                            <div class="d-flex align-items-center">
                                <h4>Matches</h4>
                                <span class="match-count-badge">@_model.Matches.Count</span>
                            </div>
                            <button type="button" class="btn btn-sm d-flex align-items-center green-button" @onclick="AddMatch">
                                <span class="bi bi-plus-circle-fill"></span>
                                <span class="d-none d-md-inline ms-2">Add Match</span>
                            </button>
                        </div>

                        @for (var i = 0; i < _model.Matches.Count; i++)
                        {
                            var matchIndex = i;
                            <div class="match-card">
                            <!-- Desktop View -->
                            <div class="d-none d-md-block">
                                <div class="match-card-row">
                                    <div class="match-card-kickoff">
                                        <label class="form-label">Kick-off</label>
                                        <UtcInputDate Class="form-control" @bind-Value="_model.Matches[matchIndex].MatchDateTimeUtc" />
                                    </div>

                                    <div class="match-card-team-select">
                                        <label class="form-label">Home</label>
                                        <InputSelect class="form-control" @bind-Value="_model.Matches[matchIndex].HomeTeamId">
                                            <option value="0">Select Team</option>
                                            @foreach (var t in _teams)
                                            {
                                                <option value="@t.Id">@t.Name</option>
                                            }
                                        </InputSelect>
                                    </div>

                                    <img src="@GetTeamLogoUrl(_model.Matches[matchIndex].HomeTeamId)" class="match-logo-large" alt="" />
                                    <span class="vs-badge">vs</span>
                                    <img src="@GetTeamLogoUrl(_model.Matches[matchIndex].AwayTeamId)" class="match-logo-large" alt="" />

                                    <div class="match-card-team-select">
                                        <label class="form-label">Away</label>
                                        <InputSelect class="form-control" @bind-Value="_model.Matches[matchIndex].AwayTeamId">
                                            <option value="0">Select Team</option>
                                            @foreach (var t in _teams)
                                            {
                                                <option value="@t.Id">@t.Name</option>
                                            }
                                        </InputSelect>
                                    </div>

                                    <button type="button" class="btn btn-sm red-button match-card-delete" @onclick="() => RemoveMatch(matchIndex)"><span class="bi bi-trash"></span></button>
                                </div>
                            </div>

                            <!-- Mobile View -->
                            <div class="d-md-none match-card-mobile">
                                <div class="match-card-header">
                                    <UtcInputDate Class="form-control" @bind-Value="_model.Matches[matchIndex].MatchDateTimeUtc" />
                                    <button type="button" class="btn btn-sm red-button" @onclick="() => RemoveMatch(matchIndex)"><span class="bi bi-trash"></span></button>
                                </div>

                                <div class="match-card-mobile-teams">
                                    <img src="@GetTeamLogoUrl(_model.Matches[matchIndex].HomeTeamId)" class="match-logo-large" alt="" />
                                    <div class="team-select-wrapper">
                                        <InputSelect class="form-control" @bind-Value="_model.Matches[matchIndex].HomeTeamId">
                                            <option value="0">Home</option>
                                            @foreach (var t in _teams)
                                            {
                                                <option value="@t.Id">@t.Abbreviation</option>
                                            }
                                        </InputSelect>
                                    </div>
                                    <span class="vs-badge">vs</span>
                                    <div class="team-select-wrapper">
                                        <InputSelect class="form-control" @bind-Value="_model.Matches[matchIndex].AwayTeamId">
                                            <option value="0">Away</option>
                                            @foreach (var t in _teams)
                                            {
                                                <option value="@t.Id">@t.Abbreviation</option>
                                            }
                                        </InputSelect>
                                    </div>
                                    <img src="@GetTeamLogoUrl(_model.Matches[matchIndex].AwayTeamId)" class="match-logo-large" alt="" />
                                </div>
                            </div>
                            </div>
                        }
                    </div>
                </ChildContent>
            </BaseFormComponent>
        }
    </div>
</div>

@code {
    [Parameter]
    public int RoundId { get; set; }

    private UpdateRoundRequest? _model;
    private List<TeamDto> _teams = [];
    private int _seasonId;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        _errorMessage = null;
        try
        {
            var roundDetails = await Http.GetFromJsonAsync<RoundDetailsDto>($"api/admin/rounds/{RoundId}");
            if (roundDetails != null)
            {
                _seasonId = roundDetails.Round.SeasonId;
                _model = new UpdateRoundRequest
                {
                    RoundNumber = roundDetails.Round.RoundNumber,
                    ApiRoundName = roundDetails.Round.ApiRoundName ?? string.Empty,
                    StartDateUtc = roundDetails.Round.StartDateUtc,
                    DeadlineUtc = roundDetails.Round.DeadlineUtc,
                    Status = roundDetails.Round.Status,
                    Matches = roundDetails.Matches.Select(m => new UpdateMatchRequest
                    {
                        Id = m.Id,
                        HomeTeamId = m.HomeTeamId,
                        AwayTeamId = m.AwayTeamId,
                        MatchDateTimeUtc = m.MatchDateTimeUtc
                    }).ToList()
                };
            }

            _teams = await Http.GetFromJsonAsync<List<TeamDto>>("api/admin/teams") ?? [];
        }
        catch (Exception)
        {
            _errorMessage = "Could not load round details.";
        }
    }

    private void ApplyStartDateToMatches()
    {
        if (_model == null)
            return;

        var newDate = _model.StartDateUtc;
        foreach (var match in _model.Matches)
        {
            var originalTime = match.MatchDateTimeUtc.TimeOfDay;
            match.MatchDateTimeUtc = newDate.Date + originalTime;
        }
    }

    private void AddMatch() => _model?.Matches.Add(new UpdateMatchRequest { MatchDateTimeUtc = _model.StartDateUtc });

    private void RemoveMatch(int index)
    {
        if (_model != null && index >= 0 && index < _model.Matches.Count)
            _model.Matches.RemoveAt(index);
    }

    private string GetTeamLogoUrl(int teamId)
    {
        if (teamId < 1)
            return "https://placehold.co/25x25/transparent/transparent?text=";

        return _teams.FirstOrDefault(t => t.Id == teamId)?.LogoUrl ?? "";
    }

    private Task<HttpResponseMessage> HandleUpdateRoundAsync()
    {
        return Http.PutAsJsonAsync($"api/admin/rounds/{RoundId}/update", _model);
    }
}