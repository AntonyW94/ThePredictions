@page "/admin/seasons"

@attribute [Authorize(Roles = RoleNames.Administrator)]

@inject HttpClient Http
@inject NavigationManager NavigationManager

@using ThePredictions.Contracts.Admin.Seasons

<PageTitle>Manage Seasons</PageTitle>

<div class="page-container admin-light">
    <div class="admin-table-container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold mb-0">Manage Seasons</h3>
            <button class="btn d-flex align-items-center green-button" @onclick='() => NavigationManager.NavigateTo("/admin/seasons/create")'>
                <span class="bi bi-plus-circle-fill"></span>
                <span class="d-none d-md-inline ms-2">Create Season</span>
            </button>
        </div>

        <ApiError Message="@_errorMessage" />

        @if (_seasons == null)
        {
            <div class="d-flex justify-content-center align-items-center py-5">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            <div class="admin-tabs">
                <button class="admin-tab @(_activeTab == "in-progress" ? "active" : "")" @onclick='() => _activeTab = "in-progress"'>
                    In Progress
                    @if (_inProgressSeasons.Any())
                    {
                        <span class="match-count-badge">@_inProgressSeasons.Count</span>
                    }
                </button>
                <button class="admin-tab @(_activeTab == "upcoming" ? "active" : "")" @onclick='() => _activeTab = "upcoming"'>
                    Upcoming
                    @if (_upcomingSeasons.Any())
                    {
                        <span class="match-count-badge" style="background: var(--blue-700)">@_upcomingSeasons.Count</span>
                    }
                </button>
                <button class="admin-tab @(_activeTab == "past" ? "active" : "")" @onclick='() => _activeTab = "past"'>
                    Past
                    @if (_pastSeasons.Any())
                    {
                        <span class="match-count-badge" style="background: var(--grey-500)">@_pastSeasons.Count</span>
                    }
                </button>
            </div>

            @if (GetActiveTabSeasons().Any())
            {
                <div class="member-list">
                    @foreach (var season in GetActiveTabSeasons())
                    {
                        <div class="member-row season-row">
                            <div class="season-row-icon">
                                <span class="bi @(season.CompetitionType == 1 ? "bi-trophy" : "bi-table")"></span>
                            </div>
                            <div class="member-info">
                                <span class="member-name">@season.Name</span>
                                <span class="member-date">
                                    @season.StartDateUtc.ToString("dd MMM yyyy") — @season.EndDateUtc.ToString("dd MMM yyyy")
                                </span>
                                <span class="season-status-pills">
                                    @if (season.DraftCount > 0)
                                    {
                                        <span class="season-status-pill draft">@season.DraftCount Draft</span>
                                    }
                                    @if (season.PublishedCount > 0)
                                    {
                                        <span class="season-status-pill published">@season.PublishedCount Published</span>
                                    }
                                    @if (season.InProgressCount > 0)
                                    {
                                        <span class="season-status-pill in-progress">@season.InProgressCount In Progress</span>
                                    }
                                    @if (season.CompletedCount > 0)
                                    {
                                        <span class="season-status-pill completed">@season.CompletedCount Completed</span>
                                    }
                                </span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <div class="form-check form-switch mb-0" title="Toggle Active">
                                    <input type="checkbox" class="form-check-input"
                                           checked="@season.IsActive"
                                           @onchange="() => ToggleIsActive(season)" />
                                </div>
                            </div>
                            <div class="season-row-actions">
                                <button class="btn btn-sm purple-accent-button" @onclick="() => ManageRounds(season.Id)" title="Manage Rounds">
                                    <span class="bi bi-calendar3-range me-1"></span><span class="d-none d-lg-inline">Rounds</span>
                                </button>
                                <button class="btn btn-sm green-button" @onclick="() => EditSeason(season.Id)" title="Edit Season">
                                    <span class="bi bi-pencil-fill me-1"></span><span class="d-none d-lg-inline">Edit</span>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <span class="bi bi-calendar3 empty-state-icon"></span>
                    <p class="empty-state-title">No @_activeTab.Replace("-", " ") seasons</p>
                    <p class="empty-state-text">Seasons in this category will appear here.</p>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<SeasonDto>? _seasons;
    private string? _errorMessage;
    private string _activeTab = "in-progress";

    private List<SeasonDto> _inProgressSeasons = [];
    private List<SeasonDto> _upcomingSeasons = [];
    private List<SeasonDto> _pastSeasons = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadSeasons();
    }

    private async Task LoadSeasons()
    {
        _errorMessage = null;
        try
        {
            _seasons = await Http.GetFromJsonAsync<List<SeasonDto>>("api/admin/seasons");

            if (_seasons != null)
            {
                var now = DateTime.UtcNow;
                _inProgressSeasons = _seasons.Where(s => s.StartDateUtc <= now && s.EndDateUtc >= now).ToList();
                _upcomingSeasons = _seasons.Where(s => s.StartDateUtc > now).ToList();
                _pastSeasons = _seasons.Where(s => s.EndDateUtc < now).ToList();
            }
        }
        catch (Exception)
        {
            _errorMessage = "An error occurred while loading seasons.";
        }
    }

    private async Task ToggleIsActive(SeasonDto seasonToUpdate)
    {
        _errorMessage = null;

        var newStatus = !seasonToUpdate.IsActive;
        var index = _seasons!.IndexOf(seasonToUpdate);
        var updatedSeason = seasonToUpdate with { IsActive = newStatus };

        _seasons[index] = updatedSeason;

        try
        {
            var response = await Http.PutAsJsonAsync($"api/admin/seasons/{seasonToUpdate.Id}/status", newStatus);
            if (!response.IsSuccessStatusCode)
            {
                _errorMessage = "Failed to update season status.";
                _seasons[index] = seasonToUpdate;
            }
        }
        catch
        {
            _errorMessage = "An unexpected error occurred.";
            _seasons[index] = seasonToUpdate;
        }

        await LoadSeasons();
        StateHasChanged();
    }

    private List<SeasonDto> GetActiveTabSeasons() => _activeTab switch
    {
        "upcoming" => _upcomingSeasons,
        "past" => _pastSeasons,
        _ => _inProgressSeasons
    };

    private void EditSeason(int seasonId) => NavigationManager.NavigateTo($"/admin/seasons/edit/{seasonId}");
    private void ManageRounds(int seasonId) => NavigationManager.NavigateTo($"/admin/seasons/{seasonId}/rounds");
}
