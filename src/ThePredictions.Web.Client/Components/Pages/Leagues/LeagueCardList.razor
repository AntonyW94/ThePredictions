@using ThePredictions.Contracts.Leagues
@using System.Globalization

@if (Leagues == null || !Leagues.Any())
{
    <div class="empty-state">
        <span class="bi bi-trophy empty-state-icon"></span>
        <p class="empty-state-title">No leagues yet</p>
        <p class="empty-state-text">Leagues in this category will appear here.</p>
    </div>
}
else
{
    <div class="member-list">
        @foreach (var league in Leagues)
        {
            <div class="member-row league-row">
                <div class="member-info">
                    <span class="member-name">@league.Name</span>
                    <span class="member-date">@league.SeasonName</span>
                    <span class="season-status-pills">
                        <span class="season-status-pill" style="background: var(--green-600); color: var(--white)">
                            @(league.Price > 0 ? league.Price.ToString("C", new CultureInfo("en-GB")) : "FREE")
                        </span>
                        <span class="season-status-pill" style="background: var(--blue-700); color: var(--white)">
                            @league.MemberCount @(league.MemberCount == 1 ? "Member" : "Members")
                        </span>
                        @if (league.EntryCode != "Public")
                        {
                            <span class="season-status-pill" style="background: var(--purple-300); color: var(--white)">
                                @league.EntryCode
                            </span>
                        }
                    </span>
                </div>
                <div class="season-row-actions">
                    <a class="btn btn-sm purple-accent-button" href="@($"/leagues/{league.Id}/prizes")" title="Prizes">
                        <span class="bi bi-trophy-fill me-1"></span><span class="d-none d-lg-inline">Prizes</span>
                    </a>
                    <a class="btn btn-sm blue-light-button" href="/leagues/@league.Id/members" title="Members">
                        <span class="bi bi-people-fill me-1"></span><span class="d-none d-lg-inline">Members</span>
                    </a>
                    <button class="btn btn-sm green-button" @onclick="() => OnEditLeague.InvokeAsync(league.Id)" title="Edit">
                        <span class="bi bi-pencil-fill me-1"></span><span class="d-none d-lg-inline">Edit</span>
                    </button>
                    <button class="btn btn-sm red-button" @onclick="() => OnDeleteLeague.InvokeAsync((league.Id, league.Name))" title="Delete">
                        <span class="bi bi-trash-fill"></span>
                    </button>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter, EditorRequired]
    public List<LeagueDto>? Leagues { get; set; }

    [Parameter]
    public EventCallback<int> OnEditLeague { get; set; }

    [Parameter]
    public EventCallback<(int leagueId, string leagueName)> OnDeleteLeague { get; set; }
}
