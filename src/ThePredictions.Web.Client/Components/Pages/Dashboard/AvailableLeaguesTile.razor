@inject IDashboardStateService DashboardState
@inject IBrowserService BrowserService
@inject IJSRuntime JsRuntime

@implements IAsyncDisposable

@using ThePredictions.Web.Client.Services.Browser
@using ThePredictions.Web.Client.Services.Dashboard
@using System.Globalization

<div class="section h-100">
    <h3 class="text-white text-center fw-bold mb-4">Available Leagues</h3>

    <ApiError Message="@DashboardState.AvailableLeaguesErrorMessage" />

    @if (DashboardState.IsAvailableLeaguesLoading)
    {
        <div class="d-flex justify-content-center align-items-center flex-grow-1">
            <div class="spinner-border text-light" role="status">
                <span class="visually-hidden">Loading leagues...</span>
            </div>
        </div>
    }
    else if (DashboardState.AvailableLeagues.Any())
    {
        <div class="carousel-wrapper">
            <div class="carousel-container" @ontouchstart="HandleTouchStart" @ontouchmove="HandleTouchMove" @ontouchend="HandleTouchEnd">
                @if (_showTwoItems && DashboardState.AvailableLeagues.Count > 1)
                {
                    <button class="carousel-btn" @onclick="ShowPrevious" disabled="@(_currentIndex == 0)">
                        <span class="bi bi-chevron-left"></span>
                    </button>
                }

                <div class="carousel-track-wrapper" id="available-leagues-track-wrapper">
                    <div class="carousel-track" style="@_trackStyle">
                        @foreach (var league in DashboardState.AvailableLeagues)
                        {
                            <div class="carousel-item-wrapper">
                                <div class="carousel-item-content">
                                    <div class="card slide available-league-card">
                                        <div class="body centered">
                                            <h5 class="fw-bold mb-1">@league.Name</h5>
                                            <small class="text-white-50 fw-bold d-block mb-3">@league.SeasonName</small>

                                            <div class="available-league-meta">
                                                <div class="badge-group badge-group--red">
                                                    <span class="badge-icon"><i class="bi bi-alarm"></i></span>
                                                    <LocalTime UtcDate="@league.EntryDeadlineUtc"/>
                                                </div>

                                                <div class="available-league-meta-row">
                                                    <div class="badge-group badge-group--blue">
                                                        <span class="badge-icon"><i class="bi bi-people-fill"></i></span>
                                                        <span>@league.MemberCount</span>
                                                    </div>

                                                    <div class="badge-group badge-group--green">
                                                        <span class="badge-icon"><i class="bi bi-cash-stack"></i></span>
                                                        <span>@(league.Price > 0 ? league.Price.ToString("C", new CultureInfo("en-GB")) : "Free Entry")</span>
                                                    </div>

                                                    <div class="badge-group badge-group--green">
                                                        <span class="badge-icon"><i class="bi bi-trophy-fill"></i></span>
                                                        <span>@(league.EstPot > 0 ? league.EstPot.ToString("C", new CultureInfo("en-GB")) : "£0.00")</span>
                                                    </div>
                                                </div>
                                            </div>

                                            <button class="btn purple-accent-button w-100 mt-3"
                                                    @onclick="() => HandleJoinLeagueAsync(league.Id)"
                                                    disabled="@_isBusy">
                                                Join
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @if (_showTwoItems && DashboardState.AvailableLeagues.Count > 1)
                {
                    <button class="carousel-btn" @onclick="ShowNext" disabled="@IsAtEnd()">
                        <span class="bi bi-chevron-right"></span>
                    </button>
                }
            </div>

            @if (NumberOfDots > 1)
            {
                <div class="carousel-dots">
                    @for (var i = 0; i < NumberOfDots; i++)
                    {
                        var dotIndex = i;
                        <span class="carousel-dot @(i == _currentIndex ? "active" : "")" @onclick="() => GoToSlide(dotIndex)"></span>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="d-flex flex-column align-items-center justify-content-center flex-grow-1">
            <i class="bi bi-people empty-state-icon"></i>
            <p class="text-white-50 mt-2 mb-0 text-center">No public leagues available right now.</p>
        </div>
    }

    @if (DashboardState.HasAvailablePrivateLeagues)
    {
        <div class="mt-auto pt-4">
            <button class="btn blue-light-button w-100" @onclick="ShowJoinPrivateLeagueModal">Join Private League with Code</button>
        </div>
    }
</div>

@if (_showPrivateLeagueModal)
{
    <JoinPrivateLeagueModal OnClose="HideJoinPrivateLeagueModal" />
}

@code {
    private int _currentIndex;
    private double _touchStartX;
    private string _trackStyle = "transform: translateX(0%);";
    private bool _showTwoItems;
    private bool _isBusy;
    private bool _showPrivateLeagueModal;

    protected override async Task OnInitializedAsync()
    {
        DashboardState.OnStateChange += StateHasChanged;
        _showTwoItems = await BrowserService.IsTabletOrAbove();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (DashboardState.AvailableLeagues.Any())
            await UpdateCarouselHeightAsync();
    }

    private int NumberOfDots
    {
        get
        {
            if (DashboardState.AvailableLeagues.Count <= 1)
                return 0;

            return DashboardState.AvailableLeagues.Count;
        }
    }

    private void HandleTouchStart(TouchEventArgs e)
    {
        _touchStartX = e.Touches[0].ClientX;
    }

    private static void HandleTouchMove(TouchEventArgs e)
    {
    }

    private async Task HandleTouchEnd(TouchEventArgs e)
    {
        var touchEndX = e.ChangedTouches[0].ClientX;
        var diffX = _touchStartX - touchEndX;

        if (!(Math.Abs(diffX) > 50))
            return;

        if (diffX > 0)
            await ShowNext();
        else
            await ShowPrevious();
    }

    private async Task GoToSlide(int index)
    {
        if (index < 0 || index >= NumberOfDots)
            return;

        _currentIndex = index;
        await UpdateTrackStyle();
    }

    private async Task ShowPrevious()
    {
        if (_currentIndex <= 0)
            return;

        _currentIndex--;
        await UpdateTrackStyle();
    }

    private async Task ShowNext()
    {
        if (IsAtEnd())
            return;

        _currentIndex++;
        await UpdateTrackStyle();
    }

    private async Task UpdateTrackStyle()
    {
        _trackStyle = $"transform: translateX(-{_currentIndex * 100}%);";
        await UpdateCarouselHeightAsync();
    }

    private async Task UpdateCarouselHeightAsync()
    {
        await JsRuntime.InvokeVoidAsync("blazorInterop.updateCarouselHeight", "available-leagues-track-wrapper", _currentIndex, 1);
    }

    private bool IsAtEnd()
    {
        return _currentIndex >= DashboardState.AvailableLeagues.Count - 1;
    }

    private async Task ShowJoinPrivateLeagueModal()
    {
        _showPrivateLeagueModal = true;
        await Task.Delay(50);
        await JsRuntime.InvokeVoidAsync("blazorInterop.showModal", "joinPrivateLeagueModal");
    }

    private async Task HideJoinPrivateLeagueModal()
    {
        await JsRuntime.InvokeVoidAsync("blazorInterop.hideModal", "joinPrivateLeagueModal");
        _showPrivateLeagueModal = false;
    }

    private async Task HandleJoinLeagueAsync(int leagueId)
    {
        _isBusy = true;

        await DashboardState.JoinPublicLeagueAsync(leagueId);

        _isBusy = false;
    }

    public ValueTask DisposeAsync()
    {
        DashboardState.OnStateChange -= StateHasChanged;
        return ValueTask.CompletedTask;
    }
}
