@inject IDashboardStateService DashboardState
@inject IBrowserService BrowserService
@inject IJSRuntime JsRuntime
@inject NavigationManager NavigationManager

@using ThePredictions.Web.Client.Services.Browser
@using ThePredictions.Web.Client.Services.Dashboard

@implements IAsyncDisposable

<div class="section h-100">
    <h3 class="text-white text-center fw-bold mb-4">League Admin</h3>

    <ApiError Message="@DashboardState.PendingMembersErrorMessage" />

    @if (DashboardState.IsPendingMembersLoading)
    {
        <div class="d-flex justify-content-center align-items-center flex-grow-1">
            <div class="spinner-border text-white" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (DashboardState.AdminLeagues.Any())
    {
        var hasPending = DashboardState.PendingMembers.Any();
        var multipleLeagues = DashboardState.AdminLeagues.Count > 1;
        var showAllSlide = hasPending && multipleLeagues;
        var totalSlides = (showAllSlide ? 1 : 0) + DashboardState.AdminLeagues.Count;

        <div class="carousel-wrapper league-admin-carousel">
            <div class="carousel-container" @ontouchstart="HandleTouchStart" @ontouchmove="HandleTouchMove" @ontouchend="HandleTouchEnd">
                @if (_showArrows && totalSlides > 1)
                {
                    <button class="carousel-btn" @onclick="ShowPrevious" disabled="@(_currentIndex == 0)">
                        <span class="bi bi-chevron-left"></span>
                    </button>
                }

                <div class="carousel-track-wrapper">
                    <div class="carousel-track" style="transform: translateX(-@(_currentIndex * 100)%);">

                        @if (showAllSlide)
                        {
                            <div class="carousel-item-wrapper">
                                <div class="carousel-item-content">
                                    <div class="card slide">
                                        <div class="header">
                                            <h5 class="fw-bold text-white">All Requests</h5>
                                            <small class="text-white-50 fw-bold">@DashboardState.PendingMembers.Count pending</small>
                                        </div>
                                        <div class="body">
                                            <div class="pending-members-list">
                                                @{
                                                    var grouped = DashboardState.PendingMembers
                                                        .GroupBy(m => new { m.LeagueId, m.LeagueName })
                                                        .ToList();
                                                }
                                                @foreach (var league in grouped)
                                                {
                                                    <small class="text-white-50 text-uppercase fw-bold d-block mb-2 mt-2">@league.Key.LeagueName</small>
                                                    @foreach (var member in league)
                                                    {
                                                        <div class="pending-member-row">
                                                            <div class="d-flex align-items-center gap-2">
                                                                <div class="member-avatar member-avatar--sm">@member.MemberName[0]</div>
                                                                <div>
                                                                    <div class="text-white fw-bold text-sm">@member.MemberName</div>
                                                                    <small class="text-white-50 text-xs">@FormatTimeAgo(member.JoinedAtUtc)</small>
                                                                </div>
                                                            </div>
                                                            <div class="d-flex gap-2">
                                                                <button class="btn btn-sm pending-member-approve" @onclick="() => Approve(member.LeagueId, member.UserId)" disabled="@_isProcessing">
                                                                    <i class="bi bi-check-lg"></i>
                                                                </button>
                                                                <button class="btn btn-sm pending-member-reject" @onclick="() => Reject(member.LeagueId, member.UserId)" disabled="@_isProcessing">
                                                                    <i class="bi bi-x-lg"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }

                        @foreach (var league in DashboardState.AdminLeagues)
                        {
                            var leaguePending = DashboardState.PendingMembers
                                .Where(m => m.LeagueId == league.LeagueId)
                                .ToList();

                            <div class="carousel-item-wrapper">
                                <div class="carousel-item-content">
                                    <div class="card slide">
                                        <div class="header">
                                            <h5 class="fw-bold text-white">@league.LeagueName</h5>
                                        </div>
                                        <div class="body">
                                            <div class="d-flex justify-content-center gap-3 mb-3">
                                                <div class="glass-panel d-flex align-items-center gap-2 py-2 px-3">
                                                    <i class="bi bi-people-fill text-white-50"></i>
                                                    <span class="text-white fw-bold">@league.MemberCount @(league.MemberCount == 1 ? "member" : "members")</span>
                                                </div>
                                                @if (!league.IsFree)
                                                {
                                                    <div class="glass-panel d-flex align-items-center gap-2 py-2 px-3">
                                                        <i class="bi bi-cash-stack text-green-600"></i>
                                                        <span class="text-green-600 fw-bold">@((MarkupString)$"&pound;{league.Price:0.00}") entry</span>
                                                    </div>
                                                }
                                            </div>

                                            @if (leaguePending.Any())
                                            {
                                                <div class="pending-members-list">
                                                    @foreach (var member in leaguePending)
                                                    {
                                                        <div class="pending-member-row">
                                                            <div class="d-flex align-items-center gap-2">
                                                                <div class="member-avatar member-avatar--sm">@member.MemberName[0]</div>
                                                                <div>
                                                                    <div class="text-white fw-bold text-sm">@member.MemberName</div>
                                                                    <small class="text-white-50 text-xs">@FormatTimeAgo(member.JoinedAtUtc)</small>
                                                                </div>
                                                            </div>
                                                            <div class="d-flex gap-2">
                                                                <button class="btn btn-sm pending-member-approve" @onclick="() => Approve(member.LeagueId, member.UserId)" disabled="@_isProcessing">
                                                                    <i class="bi bi-check-lg"></i>
                                                                </button>
                                                                <button class="btn btn-sm pending-member-reject" @onclick="() => Reject(member.LeagueId, member.UserId)" disabled="@_isProcessing">
                                                                    <i class="bi bi-x-lg"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="d-flex flex-column align-items-center justify-content-center flex-grow-1">
                                                    <i class="bi bi-check-circle-fill text-green-600" style="font-size: 3rem;"></i>
                                                    <p class="text-white-50 mt-2 mb-0">No pending requests</p>
                                                </div>
                                            }

                                            <div class="mt-auto pt-3 d-flex flex-column gap-2">
                                                @if (!string.IsNullOrEmpty(league.EntryCode))
                                                {
                                                    <div class="glass-panel d-flex align-items-center justify-content-between py-2 px-3">
                                                        <div class="d-flex align-items-center gap-2">
                                                            <i class="bi bi-key-fill text-white-50"></i>
                                                            <span class="text-white fw-bold font-monospace">@league.EntryCode</span>
                                                        </div>
                                                        <button class="btn btn-sm p-0 text-white-50" @onclick="() => CopyEntryCode(league.EntryCode)" title="Copy entry code">
                                                            <i class="bi @(_copiedLeagueId == league.LeagueId ? "bi-check-lg text-green-600" : "bi-clipboard")"></i>
                                                        </button>
                                                    </div>
                                                }

                                                <div class="glass-panel d-flex align-items-center justify-content-center gap-2 py-2">
                                                    <i class="bi bi-clock text-white-50"></i>
                                                    <span class="text-white-50 fw-bold">Entry closes @league.EntryDeadlineUtc.ToString("dd MMM yyyy")</span>
                                                </div>

                                                <button class="btn purple-accent-button w-100" @onclick="() => ManageLeague(league.LeagueId)">
                                                    <i class="bi bi-gear me-1"></i>Manage League
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @if (_showArrows && totalSlides > 1)
                {
                    <button class="carousel-btn" @onclick="ShowNext" disabled="@(_currentIndex >= totalSlides - 1)">
                        <span class="bi bi-chevron-right"></span>
                    </button>
                }
            </div>

            @if (totalSlides > 1)
            {
                <div class="carousel-dots">
                    @for (var i = 0; i < totalSlides; i++)
                    {
                        var dotIndex = i;
                        <span class="carousel-dot @(i == _currentIndex ? "active" : "")" @onclick="() => GoToSlide(dotIndex)"></span>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private int _currentIndex;
    private double _touchStartX;
    private bool _showArrows;
    private bool _isProcessing;
    private int? _copiedLeagueId;

    protected override async Task OnInitializedAsync()
    {
        DashboardState.OnStateChange += StateHasChanged;
        _showArrows = await BrowserService.IsTabletOrAbove();
    }

    private int TotalSlides
    {
        get
        {
            var hasPending = DashboardState.PendingMembers.Any();
            var multipleLeagues = DashboardState.AdminLeagues.Count > 1;
            var showAllSlide = hasPending && multipleLeagues;
            return (showAllSlide ? 1 : 0) + DashboardState.AdminLeagues.Count;
        }
    }

    private void GoToSlide(int index)
    {
        if (index >= 0 && index < TotalSlides)
            _currentIndex = index;
    }

    private void ShowPrevious()
    {
        if (_currentIndex > 0)
            _currentIndex--;
    }

    private void ShowNext()
    {
        if (_currentIndex < TotalSlides - 1)
            _currentIndex++;
    }

    private void HandleTouchStart(TouchEventArgs e)
    {
        _touchStartX = e.Touches[0].ClientX;
    }

    private static void HandleTouchMove(TouchEventArgs e)
    {
    }

    private void HandleTouchEnd(TouchEventArgs e)
    {
        var diffX = _touchStartX - e.ChangedTouches[0].ClientX;
        if (!(Math.Abs(diffX) > 50))
            return;

        if (diffX > 0)
            ShowNext();
        else
            ShowPrevious();
    }

    private async Task Approve(int leagueId, string userId)
    {
        _isProcessing = true;
        await DashboardState.ApproveMemberAsync(leagueId, userId);
        _isProcessing = false;
        _currentIndex = 0;
    }

    private async Task Reject(int leagueId, string userId)
    {
        _isProcessing = true;
        await DashboardState.RejectMemberAsync(leagueId, userId);
        _isProcessing = false;
        _currentIndex = 0;
    }

    private async Task CopyEntryCode(string? entryCode)
    {
        if (string.IsNullOrEmpty(entryCode))
            return;

        await JsRuntime.InvokeVoidAsync("navigator.clipboard.writeText", entryCode);
        _copiedLeagueId = DashboardState.AdminLeagues.FirstOrDefault(l => l.EntryCode == entryCode)?.LeagueId;
        StateHasChanged();

        await Task.Delay(2000);
        _copiedLeagueId = null;
        StateHasChanged();
    }

    private void ManageLeague(int leagueId)
    {
        NavigationManager.NavigateTo($"/leagues/{leagueId}/edit");
    }

    private static string FormatTimeAgo(DateTime utcDate)
    {
        var elapsed = DateTime.UtcNow - utcDate;

        if (elapsed.TotalMinutes < 60)
            return $"{(int)elapsed.TotalMinutes}m ago";

        if (elapsed.TotalHours < 24)
            return $"{(int)elapsed.TotalHours}h ago";

        if (elapsed.TotalDays < 7)
            return $"{(int)elapsed.TotalDays}d ago";

        return utcDate.ToString("dd MMM");
    }

    public ValueTask DisposeAsync()
    {
        DashboardState.OnStateChange -= StateHasChanged;
        return ValueTask.CompletedTask;
    }
}
