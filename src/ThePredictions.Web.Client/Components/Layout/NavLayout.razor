@inject IAuthenticationService AuthenticationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject IThemeService ThemeService

@using ThePredictions.Web.Client.Services.Theme

<nav class="navbar navbar-expand-lg navbar-dark navbar-custom @Class">
    <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center" @onclick="GoToSmartHomepage">
            <img src="/images/logo.png" alt="The Predictions Logo" class="navbar-logo" />
            <span class="ms-2 fw-bold d-none d-sm-inline">The Predictions</span>
        </a>

        <AuthorizeView>
            <Authorized>
                <div class="navbar-auth-actions d-flex align-items-center ms-auto">
                    <button class="btn theme-toggle-btn theme-toggle-btn--labelled me-2" @onclick="ToggleTheme" title="@(ThemeService.IsDarkMode ? "Switch to light mode" : "Switch to dark mode")">
                        <span class="bi @(ThemeService.IsDarkMode ? "bi-sun-fill" : "bi-moon-fill") me-2" aria-hidden="true"></span>
                        <span class="theme-toggle-btn__label">
                            @(ThemeService.IsDarkMode ? "Light" : "Dark")<span class="d-none d-lg-inline"> Mode</span>
                        </span>
                    </button>

                    @if (context.User.IsInRole(RoleNames.Administrator))
                    {
                        <div class="dropdown me-2">
                            <button class="btn nav-icon-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Admin">
                                <span class="bi bi-gear-fill" aria-hidden="true"></span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><NavLink class="dropdown-item" href="/leagues"><span class="bi bi-trophy me-2 fw-bold"></span>Manage Leagues</NavLink></li>
                                <li><NavLink class="dropdown-item" href="/admin/seasons"><span class="bi bi-calendar3 me-2 fw-bold"></span>Manage Seasons</NavLink></li>
                                <li><NavLink class="dropdown-item" href="/admin/teams"><span class="bi bi-shield-fill me-2 fw-bold"></span>Manage Teams</NavLink></li>
                                <li><NavLink class="dropdown-item" href="/admin/users"><span class="bi bi-person-gear me-2 fw-bold"></span>Manage Users</NavLink></li>
                            </ul>
                        </div>
                    }

                    <div class="dropdown">
                        <button class="btn nav-avatar-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="User Menu">
                            <UserAvatar FirstName="@context.User.FindFirst("FirstName")?.Value"
                                        LastName="@context.User.FindFirst("LastName")?.Value"
                                        Size="sm" />
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><NavLink class="dropdown-item" href="account/details"><span class="bi bi-person-badge me-2 fw-bold"></span>My Details</NavLink></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><button class="dropdown-item d-flex align-items-center" type="button" @onclick="LogoutUser"><span class="bi bi-box-arrow-right me-2 fw-bold"></span>Log out</button></li>
                        </ul>
                    </div>
                </div>
            </Authorized>

            <NotAuthorized>
                <div class="d-flex align-items-center ms-auto">
                    <button class="btn theme-toggle-btn theme-toggle-btn--labelled" @onclick="ToggleThemeAsGuest" title="@(ThemeService.IsDarkMode ? "Switch to light mode" : "Switch to dark mode")">
                        <span class="bi @(ThemeService.IsDarkMode ? "bi-sun-fill" : "bi-moon-fill") me-2" aria-hidden="true"></span>
                        <span class="theme-toggle-btn__label">
                            @(ThemeService.IsDarkMode ? "Light" : "Dark")<span class="d-none d-lg-inline"> Mode</span>
                        </span>
                    </button>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</nav>

@code {
    [Parameter]
    public string? Class { get; set; }

    private async Task GoToSmartHomepage()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated ?? false)
            NavigationManager.NavigateTo("/dashboard", forceLoad: true);
        else
            NavigationManager.NavigateTo("/", forceLoad: true);
    }

    private async Task ToggleTheme()
    {
        await ThemeService.ToggleThemeAsync();
    }

    private async Task ToggleThemeAsGuest()
    {
        await ThemeService.ToggleThemeAsGuestAsync();
    }

    private async Task LogoutUser()
    {
        await ThemeService.ClearPreferenceAsync();
        await AuthenticationService.LogoutAsync();
        NavigationManager.NavigateTo("/", forceLoad: true);
    }
}
