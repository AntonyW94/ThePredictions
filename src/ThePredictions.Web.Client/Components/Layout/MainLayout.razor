@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@implements IDisposable

<div class="page">
    <CascadingAuthenticationState>
        <main class="@_backgroundClass">
            <NavLayout class="@_navLayoutClass" />

            <article class="content">
                <LoggingErrorBoundary @ref="_errorBoundary">
                    <ChildContent>
                        @Body
                    </ChildContent>
                    <ErrorContent Context="exception">
                        <div class="text-center py-5">
                            <p class="text-white">Something went wrong. Please try refreshing the page.</p>
                            <button class="btn btn-outline-light mt-2" @onclick="RecoverFromError">Try Again</button>
                        </div>
                    </ErrorContent>
                </LoggingErrorBoundary>
            </article>
        </main>
    </CascadingAuthenticationState>
</div>

@code {
    private LoggingErrorBoundary? _errorBoundary;
    private string _navLayoutClass = "";
    private string _backgroundClass = "";

    protected override void OnInitialized()
    {
        SetLayoutClasses();
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _errorBoundary?.Recover();
        SetLayoutClasses();
        StateHasChanged();
    }

    private void RecoverFromError()
    {
        _errorBoundary?.Recover();
    }

    private void SetLayoutClasses()
    {
        var uri = new Uri(NavigationManager.Uri);
        var path = uri.AbsolutePath;

        var isHomePage = path == "/" || path == "";
        var isAuthenticationPage = path.StartsWith("/authentication/");

        _navLayoutClass = isHomePage ? "navbar-overlay" : "";
        _backgroundClass = isAuthenticationPage ? "bg-purple-gradient" : isHomePage ? "bg-grey-100" : "";
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}