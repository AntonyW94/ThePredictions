@inject IConsentBannerService ConsentService
@using ThePredictions.Web.Client.Services.Consent
@implements IDisposable

@if (!ConsentService.HasResponded)
{
    <div class="cookie-consent" role="dialog" aria-modal="false" aria-labelledby="cookie-consent-title">
        <div class="cookie-consent__inner">
            <div class="cookie-consent__copy">
                <h2 id="cookie-consent-title" class="cookie-consent__title">We value your privacy</h2>
                <p class="cookie-consent__text">
                    We use a strictly necessary cookie to keep you signed in. We do not currently use
                    analytics or marketing cookies. You can review your choices at any time from the
                    <a href="/cookie-policy" class="cookie-consent__link">cookie policy</a> page.
                </p>

                @if (_showPreferences)
                {
                    <div class="cookie-consent__preferences">
                        <div class="cookie-consent__row">
                            <div class="cookie-consent__row-text">
                                <strong>Essential</strong>
                                <span class="cookie-consent__row-meta">Always on</span>
                                <p>Required for sign-in. Without these the site cannot function.</p>
                            </div>
                            <input type="checkbox" class="cookie-consent__toggle" checked disabled aria-label="Essential cookies (always on)" />
                        </div>

                        <div class="cookie-consent__row">
                            <div class="cookie-consent__row-text">
                                <strong>Analytics</strong>
                                <p>Helps us understand how the site is used. None set today.</p>
                            </div>
                            <input type="checkbox" class="cookie-consent__toggle" @bind="_analyticsAllowed" aria-label="Allow analytics cookies" />
                        </div>

                        <div class="cookie-consent__row">
                            <div class="cookie-consent__row-text">
                                <strong>Marketing</strong>
                                <p>Used for personalised promotions. None set today.</p>
                            </div>
                            <input type="checkbox" class="cookie-consent__toggle" @bind="_marketingAllowed" aria-label="Allow marketing cookies" />
                        </div>
                    </div>
                }
            </div>

            <div class="cookie-consent__actions">
                @if (_showPreferences)
                {
                    <button type="button" class="cookie-consent__btn cookie-consent__btn--primary" @onclick="SaveCustomAsync">Save preferences</button>
                    <button type="button" class="cookie-consent__btn cookie-consent__btn--ghost" @onclick="HidePreferences">Cancel</button>
                }
                else
                {
                    <button type="button" class="cookie-consent__btn cookie-consent__btn--primary" @onclick="AcceptAllAsync">Accept all</button>
                    <button type="button" class="cookie-consent__btn cookie-consent__btn--secondary" @onclick="RejectNonEssentialAsync">Reject non-essential</button>
                    <button type="button" class="cookie-consent__btn cookie-consent__btn--ghost" @onclick="ShowPreferences">Manage preferences</button>
                }
            </div>
        </div>
    </div>
}

@code {
    private bool _showPreferences;
    private bool _analyticsAllowed;
    private bool _marketingAllowed;

    protected override async Task OnInitializedAsync()
    {
        ConsentService.OnStateChange += StateHasChanged;
        await ConsentService.InitialiseAsync();
    }

    private void ShowPreferences()
    {
        _analyticsAllowed = ConsentService.AnalyticsAllowed;
        _marketingAllowed = ConsentService.MarketingAllowed;
        _showPreferences = true;
    }

    private void HidePreferences()
    {
        _showPreferences = false;
    }

    private async Task AcceptAllAsync()
    {
        await ConsentService.AcceptAllAsync();
    }

    private async Task RejectNonEssentialAsync()
    {
        await ConsentService.RejectNonEssentialAsync();
    }

    private async Task SaveCustomAsync()
    {
        await ConsentService.SaveCustomPreferencesAsync(_analyticsAllowed, _marketingAllowed);
        _showPreferences = false;
    }

    public void Dispose()
    {
        ConsentService.OnStateChange -= StateHasChanged;
    }
}
